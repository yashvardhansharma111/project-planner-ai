# ─────────────────────────────────────────────────────────────
# AI Project-Roadmap Generator — environment reference
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_roadmap_dev

# DNS servers for Node's resolver (comma-separated). Override when an Atlas
# `mongodb+srv://` connection fails with "querySrv ECONNREFUSED".
# Defaults to 8.8.8.8,1.1.1.1 if unset.
DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-hex-string
JWT_REFRESH_SECRET=another-different-64-char-random-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Groq — get from console.groq.com -> API Keys (free) [not used yet]
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# Email (Nodemailer) — Gmail App Password for local dev [not used yet]
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@ai-roadmap.com

# App
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:3000
